{
  "name": "4 Paws",
  "slug": "4paws",
  "version": "1.0.2",
  "orientation": "default",
  "icon": "./assets/images/icon.png",
  "scheme": "manus20260118223445",
  "userInterfaceStyle": "automatic",
  "newArchEnabled": true,
  "description": "Find trusted cat sitters near you. Book professional cat sitting services with verified sitters, real-time messaging, and secure payments. Perfect for cat owners who need reliable pet care.",
  "ios": {
    "supportsTablet": true,
    "bundleIdentifier": "com.4pawscatsitting.app",
    "infoPlist": {
      "ITSAppUsesNonExemptEncryption": false,
      "NSLocationWhenInUseUsageDescription": "Allow 4 Paws to access your location to find nearby cat sitters.",
      "NSCameraUsageDescription": "Allow 4 Paws to access your camera to take profile pictures and cat photos.",
      "NSPhotoLibraryUsageDescription": "Allow 4 Paws to access your photos to upload profile pictures and cat photos."
    },
    "config": {
      "usesNonExemptEncryption": false
    }
  },
  "android": {
    "adaptiveIcon": {
      "backgroundColor": "#E6F4FE",
      "foregroundImage": "./assets/images/android-icon-foreground.png",
      "backgroundImage": "./assets/images/android-icon-background.png",
      "monochromeImage": "./assets/images/android-icon-monochrome.png"
    },
    "edgeToEdgeEnabled": true,
    "predictiveBackGestureEnabled": false,
    "package": "space.manus.4paws.t20260118223445",
    "permissions": [
      "POST_NOTIFICATIONS",
      "ACCESS_FINE_LOCATION",
      "ACCESS_COARSE_LOCATION",
      "INTERNET",
      "CAMERA",
      "READ_EXTERNAL_STORAGE",
      "WRITE_EXTERNAL_STORAGE"
    ],
    "intentFilters": [
      {
        "action": "VIEW",
        "autoVerify": true,
        "data": [
          {
            "scheme": "manus20260118223445",
            "host": "*"
          }
        ],
        "category": [
          "BROWSABLE",
          "DEFAULT"
        ]
      }
    ]
  },
  "web": {
    "bundler": "metro",
    "output": "static",
    "favicon": "./assets/images/favicon.png"
  },
  "plugins": [
    "expo-router",
    [
      "expo-audio",
      {
        "microphonePermission": "Allow $(PRODUCT_NAME) to access your microphone."
      }
    ],
    [
      "expo-video",
      {
        "supportsBackgroundPlayback": true,
        "supportsPictureInPicture": true
      }
    ],
    [
      "expo-splash-screen",
      {
        "image": "./assets/images/splash-icon.png",
        "imageWidth": 200,
        "resizeMode": "contain",
        "backgroundColor": "#ffffff",
        "dark": {
          "backgroundColor": "#000000"
        }
      }
    ],
    [
      "expo-location",
      {
        "isIosBackgroundLocationEnabled": false
      }
    ],
    [
      "expo-image-picker",
      {
        "photosPermission": "Allow $(PRODUCT_NAME) to access your photos to upload profile pictures and cat photos.",
        "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera to take profile pictures and cat photos."
      }
    ],
    [
      "expo-build-properties",
      {
        "android": {
          "buildArchs": [
            "armeabi-v7a",
            "arm64-v8a"
          ],
          "minSdkVersion": 24,
          "targetSdkVersion": 35,
          "compileSdkVersion": 35,
          "kotlinVersion": "2.0.20",
          "usesCleartextTraffic": false,
          "enableProguardInReleaseBuilds": false,
          "extraMavenRepos": [
            "https://maven.google.com",
            "https://repo1.maven.org/maven2"
          ]
        }
      }
    ]
  ],
  "experiments": {
    "typedRoutes": true,
    "reactCompiler": true
  }
}